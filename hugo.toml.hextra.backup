baseURL = "https://tihu.github.io/tihu-hugo-blog/"
languageCode = "zh-cn"
title = "醍醐堂記_TihuBlogs"
theme = "hextra"
hasCJKLanguage = true
enableRobotsTXT = true
paginate = 10

[markup]
  [markup.goldmark]
    [markup.goldmark.renderer]
      unsafe = true
  [markup.highlight]
    style = "github-dark"
    lineNos = true

[params]
  [params.author]
    name = "Tihu"
    email = ""
  description = "醍醐,tihu,志怪,阅读,笔记体,南北朝,科幻,奇幻,播客,2082,2082ALT"
  keywords = ["醍醐", "志怪", "科幻", "播客", "阅读笔记", "历史"]
  defaultTheme = "auto"
  disableThemeToggle = false

  [params.page]
    showBreadcrumb = false
    showToc = true
    dateFormat = "2006-01-02"

  [params.search]
    enable = true

  [params.navbar]
    displayTitle = true
    width = "normal"
    sticky = true

  [params.footer]
    enable = true
    copyright = "© 2026 醍醐堂記_TihuBlogs"
    width = "normal"

# 导航菜单
[[menu.main]]
  name = "首页"
  url = "/"
  weight = 1

[[menu.main]]
  name = "文章"
  url = "/posts/"
  weight = 2

[[menu.main]]
  name = "归档"
  url = "/archives/"
  weight = 3

[[menu.main]]
  name = "搜索"
  url = "/search/"
  weight = 4

[languages]
  [languages.zh-cn]
    languageName = "中文"
    weight = 1
